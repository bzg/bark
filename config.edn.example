{ ;; Default admin email, fall-back for source that doesn't set :admin
 :admin "admin@example.com"

 ;; IMAP connection
 :imap {:host     "imap.example.com"
        :port     993
        :ssl      true
        :user     "imap-login@example.com"
        :password "secret"
        :folder   "INBOX"}

 ;; Sources: classify incoming emails by header matching at digest time.
 ;; Checked in order; first match wins.  Omit :match for a catch-all.
 ;;
 ;; Two use-cases:
 ;;   1. Mailing list (public or private) → match on :list-id
 ;;   2. Email address (alias or mailbox) → match on :delivered-to
 ;;      (fallback: :to, when the MTA does not set Delivered-To)
 :sources [
           ;; --- Use-case 1: mailing list ---
           {:name               "public-list"
            ;;
            ;; Base URL where this source's public/ directory is served (optional).
            ;; Used by bone to resolve patch file URLs from reports.json.
            ;; Example:
            ;; :bark-path "https://bark.example.org/public/public-list/"
            ;;
            ;; :list-id expects the identifier inside angle brackets,
            ;; e.g. for a header "List-Id: Org Mode <emacs-orgmode.gnu.org>",
            ;; use "emacs-orgmode.gnu.org" (not the full header value).
            :match              {:list-id "bugs.example.org"}
            ;;
            ;; The mailing list address for permission check
            :list-post          "bugs@example.org"
            ;;
            :admin              "lead@example.org"
            ;;
            ;; URL of the list archive (informational, used in HTML reports)
            :list-archive "https://list.example.org"
            ;;
            ;; Build archive URLs from message-ids (%s is replaced by the message-id).
            ;; Overrides the Archived-At header when present.
            :archive-format-string "https://list.example.org/%s"
            ;;
            ;; Per-source body triggers (optional).
            ;; Only specified actions override defaults; others keep builtins.
            ;; :triggers {:bug   {:acked ["Approved" "Confirmed" "Verified"]
            ;;                    :closed ["Canceled" "Fixed" "Resolved"]}
            ;;            :patch {:acked ["Approved" "Reviewed" "LGTM"]}}
            ;;
            ;; Per-source labels (optional).
            ;; Overrides global :labels for this source only.
            ;; :labels {:request ["POLL" "FR" "TODO" "TASK"]}
            }

           ;; --- Use-case 2: email address (alias or mailbox) ---
           {:name               "my-alias"
            :match              {:delivered-to "security@example.com"}}

           ;; Catch-all: emails that don't match any source above
           {:name "direct"}]

 ;; Global labels (optional) — override built-in subject tag lists.
 ;; Merged on top of defaults; specify only the types you want to change.
 ;; Defaults:
 ;;   :bug          ["BUG"]
 ;;   :patch        ["PATCH"]
 ;;   :request      ["POLL" "FR" "TODO"]
 ;;   :announcement ["ANN" "ANNOUNCEMENT"]
 ;;   :release      ["REL" "RELEASE"]
 ;;   :change       ["CHG" "CHANGE"]
 ;; Example:
 ;; :labels {:bug ["BUG" "DEFECT"]
 ;;                    :request ["POLL" "FR" "TODO" "RFE"]}

 ;; Global triggers (optional) — override built-in body trigger words.
 ;; Merged on top of defaults; specify only the types/actions you want to change.
 ;; Per-source :triggers (above) override these in turn.
 ;; Defaults:
 ;;   :bug          {:acked ["Approved" "Confirmed"] :owned ["Handled"] :closed ["Canceled" "Fixed"]}
 ;;   :patch        {:acked ["Approved" "Reviewed"]  :owned ["Handled"] :closed ["Canceled" "Applied"]}
 ;;   :request      {:acked ["Approved"]             :owned ["Handled"] :closed ["Canceled" "Done" "Closed"]}
 ;;   :announcement {:closed ["Canceled"]}
 ;;   :release      {:closed ["Canceled"]}
 ;;   :change       {:closed ["Canceled"]}
 ;; Example:
 ;; :triggers {:bug {:closed ["Canceled" "Fixed" "Resolved"]}
 ;;            :patch {:acked ["Approved" "Reviewed" "LGTM"]}}

 ;; Datalevin database path
 :db {:path "data/bark-db"}

 ;; Ingest settings
 :ingest {:initial-fetch 50}

 ;; Notification settings (optional — notifications disabled if absent)
 :notifications {:enabled true
                 :smtp {:host     "smtp.example.com"
                        :port     587
                        :tls      true
                        :user     "notify@example.com"
                        :password "secret"
                        :from     "bark@example.com"}}}
